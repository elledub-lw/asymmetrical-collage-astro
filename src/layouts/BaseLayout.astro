---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Asymmetrical Collage — writing on sovereignty, resilience, Bitcoin, risk, and building for the long term.',
  image,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}favicon.png`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Asymmetrical Collage`} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}

    <!-- Google Fonts: Raleway + Roboto -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;600;700&family=Roboto:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- RSS feed -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Asymmetrical Collage"
      href={`${base}rss.xml`}
    />

    <title>{title} | Asymmetrical Collage</title>

    <!--
      Dark mode: read stored preference before page renders to prevent flash.
      Falls back to OS preference, then defaults to light.
    -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('ac-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <div class="social-float">
      <a href="https://x.com/AsymmetricalC" target="_blank" rel="noopener noreferrer" aria-label="X">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.265 5.632 5.899-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://njump.me/npub1m3qu40agsucj9mkvunvak7yhq86hlgu8sc7mf4w0fhahv0y859ts04zq5r" target="_blank" rel="noopener noreferrer" aria-label="Nostr">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13.5 2L3 14h8l-1.5 8L20 10h-8z"/>
        </svg>
      </a>
    </div>
  </body>
</html>
