---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-container">
    <div class="footer-brand">
      <a href={base} class="footer-logo">Asymmetrical Collage</a>
      <p class="footer-tagline">Writing on sovereignty, resilience, and the long term.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        <li><a href={`${base}articles/`}>Articles</a></li>
        <li><a href={`${base}about/`}>About</a></li>
        <li><a href={`${base}rss.xml`}>RSS</a></li>
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} Asymmetrical Collage. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-footer-bg);
    margin-top: auto;
    transition: background-color 0.2s ease;
  }

  .footer-container {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-xl);
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-nav-text);
    text-decoration: none;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .footer-logo:hover {
    color: var(--palette-blue-green);
  }

  .footer-tagline {
    color: var(--color-footer-text);
    font-size: 0.875rem;
    line-height: 1.6;
    max-width: 32ch;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: flex-end;
  }

  .footer-nav a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-footer-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--palette-blue-green);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-nav-border);
    padding: var(--space-md) 0;
  }

  .footer-bottom p {
    font-size: 0.75rem;
    color: var(--color-footer-text);
    text-align: center;
    margin: 0;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      gap: var(--space-xl);
    }

    .footer-nav ul {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-md);
    }
  }
</style>
