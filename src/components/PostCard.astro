---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'articles'>;
}

const { post } = Astro.props;
const base = import.meta.env.BASE_URL;
const { title, date, tags, summary } = post.data;

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);

const slug = post.slug;
---

<article class="post-card">
  <div class="post-meta">
    <time datetime={date.toISOString()} class="post-date">{formattedDate}</time>
    {tags.length > 0 && (
      <div class="post-tags">
        {tags.slice(0, 3).map(tag => (
          <a href={`${base}tags/${tag}/`} class="tag">{tag}</a>
        ))}
      </div>
    )}
  </div>

  <h2 class="post-title">
    <a href={`${base}articles/${slug}/`}>{title}</a>
  </h2>

  {summary && (
    <p class="post-summary">{summary}</p>
  )}

  <a href={`${base}articles/${slug}/`} class="read-more">
    Read <span aria-hidden="true">→</span>
  </a>
</article>

<style>
  .post-card {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .post-title {
    font-size: 1.375rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .post-title a {
    color: var(--color-heading);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-title a:hover {
    color: var(--color-accent);
  }

  .post-summary {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin-bottom: var(--space-md);
    max-width: 60ch;
  }
</style>
