---
const base = import.meta.env.BASE_URL;
---

<section
  class="hero"
  id="hero"
  style={`background-image: url('${base}images/ac-hero-bg.jpg')`}
>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1 class="hero-title">Asymmetrical Collage</h1>
    <p class="hero-tagline">Riding the Waves of Change</p>
    <p class="hero-desc">An independent holding company — home to a daily blog, a weekly newsletter, and a curated portfolio.</p>
  </div>
</section>

<div class="social-float">
  <a href="https://x.com/AsymmetricalC" target="_blank" rel="noopener noreferrer" aria-label="X">
    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.265 5.632 5.899-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>
  <a href="https://njump.me/npub1m3qu40agsucj9mkvunvak7yhq86hlgu8sc7mf4w0fhahv0y859ts04zq5r" target="_blank" rel="noopener noreferrer" aria-label="Nostr">
    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
      <path d="M13.5 2L3 14h8l-1.5 8L20 10h-8z"/>
    </svg>
  </a>
</div>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 72vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center 40%;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--color-hero-overlay);
    backdrop-filter: blur(0px);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem 1.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 3.5vw, 1.875rem);
    font-weight: 600;
    color: rgba(212, 241, 244, 0.95);
    line-height: 1.3;
    margin-bottom: 1.25rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    color: rgba(212, 241, 244, 0.75);
    line-height: 1.65;
    margin-bottom: 0;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Floating social links */
  .social-float {
    position: fixed;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    z-index: 100;
  }

  .social-float a {
    width: 48px;
    height: 48px;
    background-color: var(--palette-grotto);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .social-float a:hover {
    background-color: var(--palette-orange);
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 60vh;
      background-position: center center;
    }

    .social-float {
      display: none;
    }
  }
</style>
