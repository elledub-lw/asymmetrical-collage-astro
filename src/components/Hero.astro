---
const base = import.meta.env.BASE_URL;
---

<section
  class="hero"
  id="hero"
  style={`background-image: url('${base}images/ac-hero-bg.jpg')`}
>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1 class="hero-title">Asymmetrical Collage</h1>
    <p class="hero-tagline">Riding the Waves of Change</p>
    <p class="hero-desc">An independent holding company — home to a daily blog, a weekly newsletter, and a curated portfolio.</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 72vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-size: cover;
    background-position: center 40%;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--color-hero-overlay);
    backdrop-filter: blur(0px);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem 1.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 3.5vw, 1.875rem);
    font-weight: 600;
    color: rgba(212, 241, 244, 0.95);
    line-height: 1.3;
    margin-bottom: 1.25rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    color: rgba(212, 241, 244, 0.75);
    line-height: 1.65;
    margin-bottom: 0;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 60vh;
      background-position: center center;
    }
  }
</style>
