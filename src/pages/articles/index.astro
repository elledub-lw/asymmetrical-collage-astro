---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('articles', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Gather all tags for the filter row
const tagCounts: Record<string, number> = {};
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
const allTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);

const featuredTags = ['bitcoin', 'risk', 'sovereignty', 'long-term-thinking'];
---

<BaseLayout
  title="Articles"
  description="All posts from Asymmetrical Collage — on sovereignty, resilience, Bitcoin, risk, and building for the long term."
>
  <div class="section">
    <div class="content-column">
      <header class="page-header">
        <h1 class="page-title">Articles</h1>
        <p class="post-count">{posts.length} posts</p>
      </header>

      <!-- Featured tag filter -->
      <div class="tag-filter">
        {featuredTags.map(tag => (
          <a href={`${base}tags/${tag}/`} class="tag">{tag}</a>
        ))}
        <span class="tag-divider">|</span>
        {allTags
          .filter(t => !featuredTags.includes(t))
          .map(tag => (
            <a href={`${base}tags/${tag}/`} class="tag tag-secondary">{tag}</a>
          ))
        }
      </div>

      <!-- Posts list -->
      <div class="posts-list">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
  }

  .page-title {
    font-size: 2rem;
    margin-bottom: 0;
  }

  .post-count {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 2px solid var(--color-border);
  }

  .tag-divider {
    color: var(--color-border);
    font-size: 0.875rem;
    margin: 0 0.25rem;
  }

  .tag-secondary {
    opacity: 0.65;
  }

  .tag-secondary:hover {
    opacity: 1;
  }
</style>
