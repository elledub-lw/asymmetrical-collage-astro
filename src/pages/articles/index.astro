---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('articles', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Gather all tags sorted by frequency
const tagCounts: Record<string, number> = {};
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
const allTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);

const featuredTags = ['sovereignty', 'decision-making', 'long-term-thinking', 'bitcoin'];
const moreTags = allTags.filter(t => !featuredTags.includes(t)).sort();
---

<BaseLayout
  title="Blog"
  description="All posts from Asymmetrical Collage — on sovereignty, resilience, Bitcoin, risk, and building for the long term."
>
  <div class="section">
    <div class="content-column">
      <header class="page-header">
        <h1 class="page-title">Blog</h1>
        <p class="post-count">{posts.length} posts</p>
      </header>

      <div class="tag-filter">
        {featuredTags.map(tag => (
          <a href={`${base}tags/${tag}/`} class="tag">{tag}</a>
        ))}

        <button class="more-tags-btn" id="more-tags-btn" aria-expanded="false">
          +{moreTags.length} more
        </button>

        <div class="more-tags" id="more-tags">
          {moreTags.map(tag => (
            <a href={`${base}tags/${tag}/`} class="tag tag-secondary">{tag}</a>
          ))}
        </div>
      </div>

      <div class="posts-list">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
  }

  .page-title {
    font-size: 2rem;
    margin-bottom: 0;
  }

  .post-count {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 2px solid var(--color-border);
  }

  .more-tags-btn {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .more-tags-btn:hover,
  .more-tags-btn[aria-expanded="true"] {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .more-tags {
    display: none;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
  }

  .more-tags.is-open {
    display: flex;
  }

  .tag-secondary {
    opacity: 0.65;
  }

  .tag-secondary:hover {
    opacity: 1;
  }
</style>

<script>
  const btn = document.getElementById('more-tags-btn');
  const panel = document.getElementById('more-tags');

  btn?.addEventListener('click', () => {
    const isOpen = panel?.classList.contains('is-open');
    if (isOpen) {
      panel?.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      btn.textContent = btn.textContent?.replace('−', '+') ?? btn.textContent;
    } else {
      panel?.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      btn.textContent = btn.textContent?.replace('+', '−') ?? btn.textContent;
    }
  });
</script>
