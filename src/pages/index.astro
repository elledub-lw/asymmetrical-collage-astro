---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('articles', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 8);
---

<BaseLayout title="Asymmetrical Collage">
  <Hero />

  <section class="holdings-section section">
    <div class="container">
      <div class="holdings-grid">

        <a href={`${base}articles/`} class="holding-card holding-card--live">
          <h3 class="holding-title">Laurent's Blog</h3>
          <p class="holding-desc">Daily writing on sovereignty, resilience, and building for the long term.</p>
        </a>

        <div class="holding-card holding-card--soon">
          <h3 class="holding-title">AC's Assay</h3>
          <p class="holding-desc">A weekly newsletter for people navigating change.</p>
          <span class="coming-soon">Coming Soon</span>
        </div>

        <a href={`${base}portfolio/`} class="holding-card holding-card--live">
          <h3 class="holding-title">Portfolio</h3>
          <p class="holding-desc">Companies and projects AC has built or backed.</p>
        </a>

        <a href={`${base}connect/`} class="holding-card holding-card--live">
          <h3 class="holding-title">Connect</h3>
          <p class="holding-desc">Find me on X and Nostr.</p>
        </a>

      </div>
    </div>
  </section>

  <section class="section">
    <div class="content-column">
      <div class="section-header">
        <h2 class="section-title">Recent Posts</h2>
        <a href={`${base}articles/`} class="section-link">
          All posts <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="posts-list">
        {recentPosts.map(post => (
          <PostCard post={post} />
        ))}
      </div>

      <div class="view-all">
        <a href={`${base}articles/`} class="btn btn-outline">
          View all posts
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Holdings section */
  .holdings-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl) var(--space-3xl);
  }

  .holding-card {
    border-top: 2px solid var(--color-accent);
    padding-top: var(--space-lg);
    text-decoration: none;
    display: block;
  }

  .holding-card--soon {
    border-top-color: var(--color-border);
    opacity: 0.5;
  }

  .holding-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: var(--space-xs);
    transition: color 0.2s ease;
  }

  .holding-card--live:hover .holding-title {
    color: var(--color-accent);
  }

  .holding-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin-bottom: var(--space-sm);
    max-width: none;
  }

  :global([data-theme="dark"]) .holding-desc {
    color: var(--color-text);
  }

  .coming-soon {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .holdings-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Recent posts section */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-lg);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-md);
  }

  .section-title {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-family: var(--font-heading);
    color: var(--color-heading);
    margin-bottom: 0;
  }

  .section-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-cta);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .section-link:hover {
    color: var(--color-cta-hover);
  }

  .posts-list {
    margin-bottom: var(--space-2xl);
  }

  .view-all {
    text-align: center;
  }
</style>
