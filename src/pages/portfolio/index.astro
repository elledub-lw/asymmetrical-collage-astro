---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const entries = [
  {
    name: 'nodl',
    url: 'https://nodl.eu',
    logo: '/images/nodl-logo.png',
    logoDark: '/images/nodl-logo-dark.png',
    description: 'Builds the hardware and tools for people who want to run their own Bitcoin infrastructure — and keep it that way.',
  },
  {
    name: 'nodl cloud',
    url: 'https://nodl.cloud',
    logo: '/images/nodl-cloud-logo.png',
    logoDark: '/images/nodl-cloud-logo-dark.png',
    description: 'Managed Bitcoin and Lightning node infrastructure, hosted in Europe — for people who want sovereign infrastructure without managing the hardware.',
  },
  {
    name: 'ExplainingBitcoin',
    url: 'https://explainingbitcoin.com',
    logo: null,
    logoDark: null,
    description: 'Secure Your Bitcoin Legacy.',
  },
  {
    name: 'Bitcoin in French',
    url: null,
    logo: null,
    logoDark: null,
    description: 'Six foundational Bitcoin books translated into French — works by Andreas Antonopoulos, Saifedean Ammous, Vijay Boyapati, Knut Svanholm, and Jonathan Bier. The ideas mattered too much to leave in one language.',
  },
];
---

<BaseLayout
  title="Portfolio — Asymmetrical Collage"
  description="Companies and projects built or backed by Asymmetrical Collage."
>
  <div class="section">
    <div class="content-column">
      <header class="page-header">
        <h1>Portfolio</h1>
        <p class="page-intro">Investments and projects. The list grows over time.</p>
      </header>

      <div class="portfolio-list">
        {entries.map(entry => (
          entry.url
            ? (
              <a href={entry.url} class="portfolio-entry portfolio-entry--link" target="_blank" rel="noopener noreferrer">
                <div class="entry-header">
                  {entry.logo
                    ? (
                      <div class="entry-logo-wrap">
                        <img src={entry.logo} alt={`${entry.name} logo`} class="entry-logo entry-logo--light" />
                        {entry.logoDark && <img src={entry.logoDark} alt={`${entry.name} logo`} class="entry-logo entry-logo--dark" />}
                      </div>
                    )
                    : <div class="entry-name">{entry.name}</div>
                  }
                </div>
                <p class="entry-description">{entry.description}</p>
                <span class="entry-url">{entry.url.replace('https://', '')}</span>
              </a>
            )
            : (
              <div class="portfolio-entry">
                <div class="entry-header">
                  <div class="entry-name">{entry.name}</div>
                </div>
                <p class="entry-description">{entry.description}</p>
              </div>
            )
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-3xl);
  }

  .page-intro {
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }

  :global([data-theme="dark"]) .page-intro {
    color: var(--color-text);
  }

  .portfolio-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .portfolio-entry {
    display: block;
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .portfolio-entry:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .portfolio-entry--link:hover {
    opacity: 0.8;
  }

  .entry-header {
    margin-bottom: var(--space-md);
  }

  .entry-logo-wrap {
    display: block;
  }

  .entry-logo {
    height: 48px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .entry-logo--dark {
    display: none;
  }

  :global([data-theme="dark"]) .entry-logo--light {
    display: none;
  }

  :global([data-theme="dark"]) .entry-logo--dark {
    display: block;
  }

  .entry-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-heading);
    transition: color 0.2s ease;
  }

  .portfolio-entry:hover .entry-name {
    color: var(--color-accent);
  }

  .entry-description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-sm);
    max-width: 52ch;
  }

  :global([data-theme="dark"]) .entry-description {
    color: var(--color-text);
  }

  .entry-url {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    text-transform: lowercase;
  }
</style>
